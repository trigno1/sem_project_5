generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model NFT {
  id          String    @id @default(cuid()) @map("_id")
  name        String
  description String
  minted      Boolean   @default(false)
  image       String
  owner       String?
  creatorAddress String?
  txHash      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  attributes  Json?
  qrPath      String?
  category    String?
  expiresAt   DateTime?
  issuedAt    DateTime?
  maxClaims   Int?
  claimsCount Int       @default(0)
  password    String?
  isSoulbound Boolean   @default(false)
  externalUrl String?
}
