generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model NFT {
  id          String    @id @default(cuid()) @map("_id")
  name        String
  description String
  minted      Boolean   @default(false)
  image       String
  owner       String?
  creatorAddress String?
  txHash      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  attributes  Json?
  qrPath      String?
  category    String?
  expiresAt   DateTime?
  issuedAt    DateTime?
  maxClaims   Int?
  claimsCount Int       @default(0)
  scansCount  Int       @default(0)
  password    String?
  isSoulbound Boolean   @default(false)
  isPublic    Boolean   @default(false)
  externalUrl String?
}

model ClaimRecord {
  id            String   @id @default(cuid()) @map("_id")
  dropId        String
  walletAddress String
  txHash        String?
  claimedAt     DateTime @default(now())

  @@unique([dropId, walletAddress])
}

model UserProfile {
  id        String   @id @default(cuid()) @map("_id")
  address   String   @unique
  name      String?
  bio       String?
  location  String?
  phone     String?
  avatarUrl String?
  github    String?
  linkedin  String?
  instagram String?
  twitter   String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
